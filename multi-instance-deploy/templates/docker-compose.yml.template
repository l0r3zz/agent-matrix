name: agent0-__INSTANCE_NUM__

# =============================================================================
# Agent Zero + Matrix Homeserver (Continuwuity + Caddy) — Instance __INSTANCE_NUM__
# Generated by create-instance.sh v4.0 (Continuwuity Edition)
# =============================================================================

services:
  # --- AI AGENT ---
  agent-zero:
    image: agent0ai/agent-zero
    container_name: agent0-__INSTANCE_NUM__
    hostname: agent0-__INSTANCE_NUM__
    restart: unless-stopped
    command: /bin/bash -c '/a0/usr/workdir/startup-services.sh & exec /usr/bin/python3 /usr/bin/supervisord -c /etc/supervisor/conf.d/supervisord.conf'
    mac_address: "02:42:AC:17:58:__MAC_SUFFIX__"
    ports:
      - "__WEB_PORT__:80"    # Web UI
      - "__SSH_PORT__:22"    # SSH
    environment:
      - API_KEY_OPENROUTER=${API_KEY_OPENROUTER}
      - API_KEY_OPENAI=${API_KEY_OPENAI}
      - API_KEY_ANTHROPIC=${API_KEY_ANTHROPIC}
      - API_KEY_GOOGLE=${API_KEY_GOOGLE}
      - API_KEY_GROQ=${API_KEY_GROQ}
      - AUTH_LOGIN=${AUTH_LOGIN}
      - AUTH_PASSWORD=${AUTH_PASSWORD}
      - TZ=${TZ:-America/Los_Angeles}
      - MATRIX_HOMESERVER_URL=http://agent0-__INSTANCE_NUM__-mhs:8008
    volumes:
      - ./usr:/a0/usr
    networks:
      macvlan-172-23:
        ipv4_address: 172.23.88.__INSTANCE_NUM__
      bridge-local:
    extra_hosts:
      - "agent0-__INSTANCE_NUM__-mhs:172.23.89.__INSTANCE_NUM__"

  # --- MATRIX HOMESERVER (CONTINUWUITY) ---
  continuwuity:
    image: ghcr.io/continuwuity/continuwuity:latest
    container_name: agent0-__INSTANCE_NUM__-continuwuity
    hostname: agent0-__INSTANCE_NUM__-continuwuity
    restart: unless-stopped
    environment:
      CONTINUWUITY_SERVER_NAME: "agent0-__INSTANCE_NUM__-mhs.cybertribe.com"
      CONTINUWUITY_DATABASE_PATH: "/var/lib/continuwuity"
      CONTINUWUITY_PORT: "6167"
      CONTINUWUITY_ADDRESS: "0.0.0.0"
      CONTINUWUITY_ALLOW_REGISTRATION: "true"
      CONTINUWUITY_REGISTRATION_TOKEN: "${CONTINUWUITY_REGISTRATION_TOKEN}"
      CONTINUWUITY_ALLOW_FEDERATION: "true"
      CONTINUWUITY_MAX_REQUEST_SIZE: "20000000"
      CONTINUWUITY_TRUSTED_SERVERS: '["v-site.net"]'
      CONTINUWUITY_LOG: "info"
      TZ: ${TZ:-America/Los_Angeles}
    volumes:
      - ./mhs/continuwuity-data:/var/lib/continuwuity
    networks:
      bridge-local:

  # --- TLS REVERSE PROXY (CADDY) ---
  caddy:
    image: caddy:2-alpine
    container_name: agent0-__INSTANCE_NUM__-mhs
    hostname: agent0-__INSTANCE_NUM__-mhs
    restart: unless-stopped
    volumes:
      - ./mhs/Caddyfile:/etc/caddy/Caddyfile:ro
      - ./mhs/server.crt:/etc/caddy/server.crt:ro
      - ./mhs/server.key:/etc/caddy/server.key:ro
    networks:
      macvlan-172-23:
        ipv4_address: 172.23.89.__INSTANCE_NUM__
      bridge-local:
    mac_address: "02:42:AC:17:59:__MAC_SUFFIX__"
    depends_on:
      - continuwuity

networks:
  macvlan-172-23:
    external: true
  bridge-local:
    driver: bridge
