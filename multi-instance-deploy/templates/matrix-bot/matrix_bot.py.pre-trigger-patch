#!/usr/bin/env python3
"""
Matrix Bot for Agent Zero — Stable Edition
==========================================
Simple, reliable Matrix bot that:
- Connects to a Matrix homeserver
- Auto-joins rooms on invite (with retry-backoff)
- Routes messages to Agent Zero API
- Sends responses back to Matrix

Config: .env file in same directory
State:  room_contexts.json (maps Matrix room -> A0 context)
"""

import asyncio
import json
import logging
import os
import signal
import sys
import time
from pathlib import Path

import aiohttp
import markdown
from dotenv import load_dotenv
from nio import (
    AsyncClient,
    AsyncClientConfig,
    InviteMemberEvent,
    MatrixRoom,
    RoomMessageText,
    SyncError,
)

# --- Configuration --------------------------------------------------------

BOT_DIR = Path(__file__).parent
load_dotenv(BOT_DIR / ".env")

HOMESERVER_URL   = os.getenv("MATRIX_HOMESERVER_URL", "http://localhost:8008")
USER_ID          = os.getenv("MATRIX_USER_ID", "")
ACCESS_TOKEN     = os.getenv("MATRIX_ACCESS_TOKEN", "")
DEVICE_ID        = os.getenv("MATRIX_DEVICE_ID", "AgentZeroBot")
A0_API_URL       = os.getenv("A0_API_URL", "http://localhost:80/api_message")
A0_API_KEY       = os.getenv("A0_API_KEY", "")
BOT_DISPLAY_NAME = os.getenv("BOT_DISPLAY_NAME", "Agent Zero")
AGENT_IDENTITY  = os.getenv("AGENT_IDENTITY", BOT_DISPLAY_NAME)
STATE_FILE       = BOT_DIR / "room_contexts.json"
SYNC_TIMEOUT_MS  = int(os.getenv("SYNC_TIMEOUT_MS", "30000"))

BOT_START_TIME   = time.time() * 1000  # ms -- skip messages before bot started

# --- Logging --------------------------------------------------------------

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
    datefmt="%Y-%m-%d %H:%M:%S",
)
log = logging.getLogger("matrix-bot")

# --- State ----------------------------------------------------------------

def load_state() -> dict:
    if STATE_FILE.exists():
        try:
            return json.loads(STATE_FILE.read_text())
        except Exception:
            pass
    return {}

def save_state(state: dict) -> None:
    STATE_FILE.write_text(json.dumps(state, indent=2))

room_contexts: dict[str, str] = load_state()

# --- Agent Zero API -------------------------------------------------------

async def ask_agent_zero(
    session: aiohttp.ClientSession,
    message: str,
    room_id: str,
    sender: str,
) -> str:
    context_id = room_contexts.get(room_id, "")

    # Prepend agent identity context
    message = f"[System: You are {AGENT_IDENTITY}, a sovereign AI agent on the Agent-Matrix network. Your Matrix ID is {USER_ID}. Always identify yourself as {AGENT_IDENTITY}.]\n{message}"
    payload = {"message": message, "context_id": context_id}
    if A0_API_KEY:
        payload["api_key"] = A0_API_KEY

    headers = {"Content-Type": "application/json"}
    if A0_API_KEY:
        headers["X-API-KEY"] = A0_API_KEY

    log.info("Sending to Agent Zero | room=%s | ctx=%s | from=%s",
             room_id, context_id or "NEW", sender)

    try:
        async with session.post(
            A0_API_URL,
            json=payload,
            headers=headers,
            timeout=aiohttp.ClientTimeout(total=300),
        ) as resp:
            if resp.status == 200:
                data = await resp.json()
                reply = data.get("response", "").strip()
                new_ctx = data.get("context_id", "")
                if new_ctx and new_ctx != context_id:
                    room_contexts[room_id] = new_ctx
                    save_state(room_contexts)
                    log.info("Context saved | room=%s | ctx=%s", room_id, new_ctx)
                return reply or "(Agent Zero returned an empty response)"
            elif resp.status == 404 and context_id:
                log.info("Clearing stale context for room %s, retrying...", room_id)
                del room_contexts[room_id]
                save_state(room_contexts)
                payload["context_id"] = ""
                async with session.post(
                    A0_API_URL, json=payload, headers=headers,
                    timeout=aiohttp.ClientTimeout(total=300),
                ) as retry:
                    if retry.status == 200:
                        data = await retry.json()
                        reply = data.get("response", "").strip()
                        new_ctx = data.get("context_id", "")
                        if new_ctx:
                            room_contexts[room_id] = new_ctx
                            save_state(room_contexts)
                        return reply or "(Agent Zero returned an empty response)"
                return "Agent Zero context error. Check bot logs."
            else:
                body = await resp.text()
                log.error("Agent Zero API error %s: %s", resp.status, body[:200])
                return "Agent Zero API error %s. Check bot logs." % resp.status
    except asyncio.TimeoutError:
        return "Agent Zero is taking longer than expected. Try again."
    except aiohttp.ClientConnectorError as e:
        log.error("Cannot connect to Agent Zero API: %s", e)
        return "Cannot reach Agent Zero. Is the container running?"
    except Exception as e:
        log.exception("Unexpected error calling Agent Zero: %s", e)
        return "Unexpected error: %s" % e

# --- Event Handlers -------------------------------------------------------

async def on_invite(room: MatrixRoom, event: InviteMemberEvent, client: AsyncClient) -> None:
    """Auto-join on invite with retry-backoff for cold federation."""
    if event.membership != "invite" or event.state_key != USER_ID:
        return

    log.info("Invited to %s by %s -- joining...", room.room_id, event.sender)
    for attempt in range(4):
        if attempt > 0:
            delay = 5 * (attempt + 1)
            log.info("Retry %d/3 -- waiting %ds...", attempt, delay)
            await asyncio.sleep(delay)
        result = await client.join(room.room_id)
        if hasattr(result, "room_id"):
            log.info("Joined room: %s (attempt %d)", room.room_id, attempt + 1)
            await client.room_send(
                room_id=room.room_id,
                message_type="m.room.message",
                content={
                    "msgtype": "m.text",
                    "body": "Hello! I'm %s, an AI agent powered by Agent Zero." % BOT_DISPLAY_NAME,
                },
            )
            return
        log.warning("Join attempt %d/4 failed: %s", attempt + 1, result)
    log.error("Failed to join %s after 4 attempts.", room.room_id)

async def on_message(
    room: MatrixRoom,
    event: RoomMessageText,
    client: AsyncClient,
    http_session: aiohttp.ClientSession,
) -> None:
    """Route incoming messages to Agent Zero."""
    if event.sender == USER_ID:
        return

    if event.server_timestamp < BOT_START_TIME:
        log.info("Skipping pre-restart message from %s", event.sender)
        return

    body = event.body.strip()
    if not body:
        return

    log.info("Message in %s from %s: %s", room.room_id, event.sender, body[:120])

    await client.room_typing(room.room_id, typing_state=True, timeout=60000)

    try:
        full_message = (
            "[MATRIX MESSAGE - reply with plain conversational text only, "
            "DO NOT use any Matrix tools, do not send messages via MCP]\n"
            "From: %s\n"
            "Room: %s\n\n"
            "%s"
        ) % (event.sender, room.display_name or room.room_id, body)

        reply = await ask_agent_zero(
            session=http_session,
            message=full_message,
            room_id=room.room_id,
            sender=event.sender,
        )
    finally:
        await client.room_typing(room.room_id, typing_state=False)

    max_len = 32000
    chunks = [reply[i:i+max_len] for i in range(0, len(reply), max_len)]
    for chunk in chunks:
        await client.room_send(
            room_id=room.room_id,
            message_type="m.room.message",
            content={
                "msgtype": "m.text",
                "body": chunk,
                "format": "org.matrix.custom.html",
                "formatted_body": markdown.markdown(
                    chunk, extensions=["fenced_code", "tables", "nl2br"]
                ),
            },
        )
    log.info("Response sent to %s (%d chunk(s))", room.room_id, len(chunks))

# --- Main -----------------------------------------------------------------

async def main() -> None:
    if not HOMESERVER_URL or not USER_ID or not ACCESS_TOKEN:
        log.error("Missing config: MATRIX_HOMESERVER_URL, MATRIX_USER_ID, MATRIX_ACCESS_TOKEN")
        sys.exit(1)

    log.info("Starting Matrix Bot: %s @ %s", USER_ID, HOMESERVER_URL)
    log.info("Agent Zero API: %s", A0_API_URL)

    config = AsyncClientConfig(
        max_limit_exceeded=0,
        max_timeouts=0,
        store_sync_tokens=True,
    )
    client = AsyncClient(
        homeserver=HOMESERVER_URL,
        user=USER_ID,
        device_id=DEVICE_ID,
        config=config,
    )
    client.access_token = ACCESS_TOKEN
    client.user_id = USER_ID

    http_session = aiohttp.ClientSession()

    client.add_event_callback(
        lambda room, event: on_invite(room, event, client),
        InviteMemberEvent,
    )
    client.add_event_callback(
        lambda room, event: on_message(room, event, client, http_session),
        RoomMessageText,
    )

    loop = asyncio.get_running_loop()
    stop = asyncio.Event()

    def _shutdown(sig):
        log.info("Received signal %s -- shutting down...", sig.name)
        stop.set()

    for sig in (signal.SIGINT, signal.SIGTERM):
        loop.add_signal_handler(sig, _shutdown, sig)

    log.info("Starting sync loop -- bot is live!")

    try:
        attempt = 0
        while not stop.is_set():
            attempt += 1
            try:
                log.info("Performing initial sync...")
                resp = await asyncio.wait_for(client.sync(timeout=10000, full_state=True), timeout=60.0)
                if isinstance(resp, SyncError):
                    log.warning("Initial sync failed: %s -- retrying in 5s", resp.message)
                    await asyncio.sleep(5)
                    continue
                log.info("Initial sync complete. Next batch: %s...", resp.next_batch[:20])
                break
            except asyncio.CancelledError:
                raise
            except Exception as e:
                backoff = min(30, 5 + attempt * 2)
                log.exception("Initial sync error: %s -- retrying in %ds", e, backoff)
                await asyncio.sleep(backoff)

        while not stop.is_set():
            try:
                resp = await asyncio.wait_for(
                    client.sync(
                        timeout=SYNC_TIMEOUT_MS,
                        full_state=False,
                        set_presence="online",
                    ),
                    timeout=45.0,
                )
                if isinstance(resp, SyncError):
                    log.warning("Sync error: %s -- retrying in 5s", resp.message)
                    await asyncio.sleep(5)
            except asyncio.CancelledError:
                break
            except Exception as e:
                log.exception("Sync loop error: %s -- retrying in 10s", e)
                await asyncio.sleep(10)
    finally:
        log.info("Closing connections...")
        await client.close()
        await http_session.close()
        log.info("Matrix bot stopped.")

if __name__ == "__main__":
    asyncio.run(main())
