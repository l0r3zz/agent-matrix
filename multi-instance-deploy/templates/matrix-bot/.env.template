# Matrix Bot Sub-Agent Configuration

# ── Matrix Connection ─────────────────────────────────────────────────────────
MATRIX_HOMESERVER_URL=http://agent0-__INSTANCE_NUM__-mhs:8008
MATRIX_USER_ID=@agent0-__INSTANCE_NUM__:agent0-__INSTANCE_NUM__-mhs.cybertribe.com
MATRIX_ACCESS_TOKEN=__MATRIX_ACCESS_TOKEN__
MATRIX_DEVICE_ID=AgentZeroBot

# ── Agent Zero API ────────────────────────────────────────────────────────────
A0_API_URL=http://localhost:80/api/api_message
A0_API_KEY=__A0_API_KEY__

# ── Bot Behavior ──────────────────────────────────────────────────────────────
TRIGGER_PREFIX=
SYNC_TIMEOUT_MS=30000
A0_AGENT_PROFILE=

# Bot Display Name (global for all rooms)
BOT_DISPLAY_NAME=Agent0-__INSTANCE_NUM__

# Identity for system prompts
AGENT_IDENTITY=Agent0-__INSTANCE_NUM__

# Optional runtime override for run-matrix-bot.sh:
#   python (default) | rust
# MATRIX_BOT_RUNTIME=python
