name: agent0-__INSTANCE_NUM__

# =============================================================================
# Agent Zero + Matrix Homeserver (Dendrite) Pair — Instance __INSTANCE_NUM__
# Generated by create-instance.sh v3.8 for g2s.cybertribe.com
# =============================================================================

services:
  # --- AI AGENT ---
  agent-zero:
    image: agent0ai/agent-zero
    container_name: agent0-__INSTANCE_NUM__
    hostname: agent0-__INSTANCE_NUM__
    restart: unless-stopped
    command: /bin/bash -c '/a0/usr/workdir/startup-services.sh & exec /usr/bin/python3 /usr/bin/supervisord -c /etc/supervisor/conf.d/supervisord.conf'
    mac_address: "02:42:AC:17:58:__MAC_SUFFIX__"
    ports:
      - "__WEB_PORT__:80"    # Web UI
      - "__SSH_PORT__:22"    # SSH
    environment:
      - API_KEY_OPENROUTER=${API_KEY_OPENROUTER}
      - API_KEY_OPENAI=${API_KEY_OPENAI}
      - API_KEY_ANTHROPIC=${API_KEY_ANTHROPIC}
      - API_KEY_GOOGLE=${API_KEY_GOOGLE}
      - API_KEY_GROQ=${API_KEY_GROQ}
      - AUTH_LOGIN=${AUTH_LOGIN}
      - AUTH_PASSWORD=${AUTH_PASSWORD}
      - TZ=${TZ:-America/Los_Angeles}
      - MATRIX_HOMESERVER_URL=http://agent0-__INSTANCE_NUM__-mhs:8008
    volumes:
      - ./usr:/a0/usr
    networks:
      macvlan-172-23:
        ipv4_address: 172.23.88.__INSTANCE_NUM__
      bridge-local:

  # --- MATRIX HOMESERVER (DENDRITE) ---
  dendrite:
    image: ghcr.io/element-hq/dendrite-monolith:v0.15.2
    container_name: agent0-__INSTANCE_NUM__-mhs
    hostname: agent0-__INSTANCE_NUM__-mhs
    restart: unless-stopped
    command:
      - "--tls-cert"
      - "/etc/dendrite/server.crt"
      - "--tls-key"
      - "/etc/dendrite/server.key"
      - "--https-bind-address"
      - ":8448"
    mac_address: "02:42:AC:17:59:__MAC_SUFFIX__"
    environment:
      - TZ=${TZ:-America/Los_Angeles}
    volumes:
      - ./mhs/dendrite.yaml:/etc/dendrite/dendrite.yaml:ro
      - ./mhs/data:/var/lib/dendrite
      - ./mhs/matrix_key.pem:/etc/dendrite/matrix_key.pem:ro
      - ./mhs/server.crt:/etc/dendrite/server.crt:ro
      - ./mhs/server.key:/etc/dendrite/server.key:ro
    networks:
      macvlan-172-23:
        ipv4_address: 172.23.89.__INSTANCE_NUM__

networks:
  macvlan-172-23:
    external: true
  bridge-local:
    driver: bridge
