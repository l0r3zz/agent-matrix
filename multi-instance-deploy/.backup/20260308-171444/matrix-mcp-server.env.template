# Server Configuration
PORT=3000

# HTTPS - disabled for internal LAN use
ENABLE_HTTPS=false

# CORS - open for internal use
CORS_ALLOWED_ORIGINS=

# OAuth - disabled, using direct Matrix access tokens
ENABLE_OAUTH=false
ENABLE_TOKEN_EXCHANGE=false

# MCP Server URL
MCP_SERVER_URL=http://localhost:3000/mcp

# Matrix homeserver (agent0-__INSTANCE_NUM__)
MATRIX_HOMESERVER_URL=http://agent0-__INSTANCE_NUM__-mhs:8008
MATRIX_DOMAIN=agent0-__INSTANCE_NUM__-mhs.cybertribe.com
MATRIX_USER_ID=@agent0-__INSTANCE_NUM__:agent0-__INSTANCE_NUM__-mhs.cybertribe.com
MATRIX_ACCESS_TOKEN=__MATRIX_ACCESS_TOKEN__
MATRIX_CLIENT_ID=
MATRIX_CLIENT_SECRET=
